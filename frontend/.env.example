# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# For development with v0 preview
# This is set automatically by v0 for Supabase auth redirects
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Python FastAPI server (LinkedIn scrape + PDF resume parse). Run: cd backend && uvicorn main:app --reload
BACKEND_URL=http://127.0.0.1:8000

# Must match backend BACKEND_AGENT_SECRET (Next /api/agents/* proxies to Python)
BACKEND_AGENT_SECRET=

# Tavily — used by /api/learning-resources/search (roadmap resource sidebar). Same key as backend TAVILY_API_KEY.
# TAVILY_API_KEY=

# Optional: semantic cache for coach (agent_cache table + pgvector). Same key as OpenAI embeddings.
# OPENAI_API_KEY=

# Same key as Vercel/server if you use it elsewhere — required on the Python server for mock-interview structured output (GET /call/:id)
# VAPI_API_KEY=

# Vapi Server URL → POST /api/vapi/webhook (optional: VAPI_WEBHOOK_SECRET must match a header you send from Vapi)
# Service role: required for the webhook to update mock_interview_sessions without a user cookie
# SUPABASE_SERVICE_ROLE_KEY=
# VAPI_WEBHOOK_SECRET=
