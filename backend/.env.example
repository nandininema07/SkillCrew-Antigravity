TAVILY_API_KEY=
TWILIO_AUTH_TOKEN=
GROQ_API_KEY=
GOOGLE_API_KEY=
APIFY_API_TOKEN=

# Agents (FastAPI /internal/agents) — same value required on Next as BACKEND_AGENT_SECRET
BACKEND_AGENT_SECRET=

# Optional: POST /api/cron/sparky/* (defaults to BACKEND_AGENT_SECRET if unset)
CRON_SECRET=

# Optional: Twilio dispatch (Sparky) — AUTH_TOKEN alone is not enough
TWILIO_ACCOUNT_SID=
TWILIO_WHATSAPP_FROM=
TWILIO_VOICE_FROM=
TWILIO_SMS_FROM=

# Optional: email via SendGrid (Twilio-owned)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Pip checkpoint summary emails (Resend). Use a verified domain "from" in production.
RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev

GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
APIFY_GOOGLE_SEARCH_ACTOR=apify/google-search-scraper

# Supabase service role (onboarding / server writes)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=
